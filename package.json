{
	"name": "cypress-cli",
	"version": "0.1.0",
	"description": "CLI tool for REPL-like LLM interactions with Cypress tests via Playwright's aria snapshot",
	"type": "module",
	"bin": {
		"cypress-cli": "./dist/client/main.js"
	},
	"scripts": {
		"build": "npm run build:iife && npm run build:ts",
		"build:demo": "npm run build && node demo/esbuild.demo.js",
		"build:driver": "node esbuild.driver.js",
		"build:iife": "node esbuild.config.js",
		"build:ts": "tsc",
		"pretest": "npm run build:iife",
		"serve:demo": "npx serve demo -l 3000",
		"test": "vitest run",
		"test:watch": "vitest --watch",
		"test:unit": "vitest run tests/unit/",
		"test:integration": "vitest run tests/integration/",
		"test:e2e": "vitest run tests/e2e/",
		"typecheck": "tsc --noEmit",
		"typecheck:driver": "tsc --noEmit -p src/driver/tsconfig.json",
		"lint": "eslint src/ tests/",
		"clean": "rm -rf dist/",
		"prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"peerDependencies": {
		"cypress": ">=12.0.0"
	},
	"dependencies": {
		"@cypress/unique-selector": "2.1.3",
		"minimist": "1.2.8",
		"zod": "3.24.2"
	},
	"devDependencies": {
		"@types/blob-util": "2.0.3",
		"@types/bluebird": "3.5.42",
		"@types/chai": "4.3.20",
		"@types/clone": "2.1.4",
		"@types/jquery": "3.5.32",
		"@types/lodash": "4.17.16",
		"@types/minimist": "1.2.5",
		"@types/node": "22.13.5",
		"@types/underscore.string": "0.0.42",
		"blob-util": "2.0.2",
		"bluebird": "3.7.2",
		"chai": "4.5.0",
		"chai-jquery": "2.1.0",
		"clone": "2.1.2",
		"cypress": "14.3.2",
		"dayjs": "1.11.13",
		"esbuild": "0.25.0",
		"eslint": "9.21.0",
		"eventemitter2": "6.4.9",
		"happy-dom": "17.4.4",
		"jquery": "3.7.1",
		"lodash": "4.17.21",
		"path-browserify": "1.0.1",
		"playwright": "^1.59.1",
		"typescript": "5.7.3",
		"typescript-eslint": "8.25.0",
		"underscore.string": "3.3.6",
		"url-parse": "1.5.10",
		"vitest": "3.0.7"
	},
	"files": [
		"dist/",
		"bin/",
		"skills/",
		"README.md",
		"LICENSE",
		"THIRD_PARTY_LICENSES"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/kylehgc/cypress-cli"
	}
}
