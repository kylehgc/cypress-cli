{
	"name": "cypress-cli",
	"version": "0.1.0",
	"description": "CLI tool for REPL-like LLM interactions with Cypress tests via Playwright's aria snapshot",
	"type": "module",
	"bin": {
		"cypress-cli": "./bin/cypress-cli.js"
	},
	"scripts": {
		"build": "npm run build:iife && npm run build:ts",
		"build:iife": "node esbuild.config.js",
		"build:ts": "tsc",
		"test": "vitest run",
		"test:watch": "vitest --watch",
		"test:unit": "vitest run tests/unit/",
		"test:integration": "vitest run tests/integration/",
		"test:e2e": "vitest run tests/e2e/",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src/ tests/",
		"clean": "rm -rf dist/"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"peerDependencies": {
		"cypress": ">=12.0.0"
	},
	"dependencies": {
		"minimist": "1.2.8",
		"zod": "3.24.2"
	},
	"devDependencies": {
		"@types/minimist": "1.2.5",
		"@types/node": "22.13.5",
		"cypress": "14.3.2",
		"esbuild": "0.25.0",
		"eslint": "9.21.0",
		"happy-dom": "17.4.4",
		"typescript": "5.7.3",
		"typescript-eslint": "^8.25.0",
		"vitest": "3.0.7"
	},
	"files": [
		"dist/",
		"bin/",
		"README.md",
		"LICENSE"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/kylehgc/cypress-cli"
	}
}
