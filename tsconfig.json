{
	"compilerOptions": {
		"target": "ESNext",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "dist",
		"rootDir": "src",
		"types": ["node"]
	},
	"include": ["src/**/*.ts"],
	"exclude": [
		"src/injected/**",
		"src/cypress/driver.cy.ts",
		"src/cypress/driverSpec.ts",
		"src/cypress/support.ts",
		"node_modules",
		"dist",
		"tests"
	]
}
